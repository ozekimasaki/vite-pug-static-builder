{
  "name": "vite-pug-static-builder",
  "version": "1.1.5",
  "description": "Vite + Pugを使用した静的サイトビルダー - 複数のPugファイルを静的HTMLとしてビルドするViteプラグイン",
  "author": "maigo999",
  "license": "MIT",
  "homepage": "https://github.com/ozekimasaki/vite-pug-static-builder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozekimasaki/vite-pug-static-builder.git"
  },
  "bugs": {
    "url": "https://github.com/ozekimasaki/vite-pug-static-builder/issues"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "static",
    "pug",
    "static-site",
    "site-builder",
    "html-generator"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "type-check": "tsc --noEmit -p .",
    "test:vite6": "cross-env VITE_MAJOR_VERSION=6 vitest run",
    "test:vite7": "cross-env VITE_MAJOR_VERSION=7 vitest run",
    "test:vite8": "cross-env VITE_MAJOR_VERSION=8 vitest run",
    "test": "pnpm test:vite8",
    "test:update": "vitest run -u",
    "test:watch": "vitest",
    "coverage": "cross-env VITE_MAJOR_VERSION=8 vitest run --coverage",
    "tsc": "tsc -p .",
    "build": "pnpm clean && pnpm tsc",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "ansis": "^4.3.1",
    "picomatch": "^4.0.2",
    "pug": "^3.0.3"
  },
  "peerDependencies": {
    "pug": "^3.0.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^2.3.3",
    "@types/pug": "^2.0.10",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "fs-extra": "^11.3.6",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vite6": "npm:vite@^6.4.3",
    "vite7": "npm:vite@^7.3.6",
    "vitest": "^4.1.10"
  }
}
